# Copy this file to .env and fill in real values on Unraid.
# Never commit .env — it's in .gitignore.

# ─── Core ─────────────────────────────────────────────────────────────
AUDREY_PORT=8000
AUDREY_LOG_LEVEL=INFO
AUDREY_CONFIG_PATH=/app/config.yaml

# ─── Ollama ───────────────────────────────────────────────────────────
# Inside ollama-net, the hostname is just "ollama".
# For local dev on the laptop, set to http://localhost:11434.
OLLAMA_HOST=http://ollama:11434

# ─── Brave Search API ─────────────────────────────────────────────────
# Get a key at https://api.search.brave.com/app/keys
# Free tier is fine for v1 (2k queries/month, 1 qps).
BRAVE_API_KEY=

# ─── Qdrant ───────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ─── Tool server ──────────────────────────────────────────────────────
# List of OpenAPI-compatible tool servers Audrey auto-discovers at startup.
# Add more here (comma-separated) to expand the model's tool surface.
TOOL_SERVERS=http://custom-tools:8001

# ─── Knowledge base ───────────────────────────────────────────────────
# Dataset roots watched by the ingest watcher. Comma-separated container
# paths — all resolve under /datasets, which is bind-mounted from
# /mnt/user/knowledge on the host. Add/remove subdirs as the library grows.
KB_DATASET_PATHS=/datasets/geology,/datasets/botany,/datasets/bushcraft,/datasets/fishing,/datasets/first-aid,/datasets/wilderness-first-aid,/datasets/herbal-medicine,/datasets/hunting,/datasets/survival,/datasets/bjj,/datasets/mma,/datasets/powerapps,/datasets/servicenow
# Where CLIP weights get cached (container path; host side is
# /mnt/user/appdata/clip-cache → /root/.cache/clip).
CLIP_CACHE_DIR=/root/.cache/clip

# ─── Per-user uploads (Phase 13) ─────────────────────────────────────
# These map into config.yaml kb.* keys. Override here if you want the
# upload UI to accept bigger files or raise the per-user ceiling.
# AUDREY_UPLOAD_ROOT=/data/uploads
# AUDREY_MAX_UPLOAD_MB=50
# AUDREY_MAX_USER_BYTES=1073741824

# ─── Auth (Phase 14) ──────────────────────────────────────────────────
# OWUI is the identity source. Audrey validates every /v1/files request
# by proxying the browser's bearer token to GET {OWUI_URL}/api/v1/auths/.
# Must be reachable from the audrey-ai container on ollama-net.
OWUI_URL=http://open-webui:8080

# ─── Memory (Qdrant-backed, semantic; Phase 12) ───────────────────────
# Collection name for per-user long-term memory. Separate from kb_text /
# kb_images so KB churn doesn't affect memory and vice versa.
MEMORY_COLLECTION=kb_memory
# Embedding model used for both memory writes and search queries. Must
# match the dim configured on the collection (nomic-embed-text = 768).
MEMORY_EMBED_MODEL=nomic-embed-text
# Cosine similarity floor for memory_search. nomic-embed-text runs warm —
# unrelated baseline ~0.4 — so 0.5 is the first value that cleanly
# separates on-topic hits from noise. Raise if you see false positives,
# lower if relevant memories get dropped.
MEMORY_SIMILARITY_THRESHOLD=0.5

# ─── Pipeline tunables ────────────────────────────────────────────────
FAST_PATH_CONFIDENCE=0.88
COMPLEXITY_TOKEN_THRESHOLD=500
MAX_DEEP_WORKERS=2
MAX_DEEP_WORKERS_CLOUD=3
GPU_CONCURRENCY=1
TOOL_MAX_ROUNDS=5
CACHE_SIZE=256
CACHE_TTL_SECONDS=600

# ─── Open WebUI (set on the open-webui container, not here) ───────────
# OPENAI_API_BASE_URL=http://audrey-ai:8000/v1
# OPENAI_API_KEY=unused
# WEBUI_AUTH=true
# ENABLE_SIGNUP=true
